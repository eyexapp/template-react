{
  "name": "react",
  "displayName": "React",
  "description": "React 19 SPA with TypeScript, Vite 7, Zustand 5 state management, Tailwind CSS 4, and React Router 7",
  "category": "frontend",
  "language": "typescript",
  "framework": "react",
  "stack": ["react-19", "typescript", "vite-7", "zustand-5", "tailwindcss-4", "react-router-7", "react-i18next", "vitest", "playwright"],
  "features": ["spa", "state-management", "routing", "i18n", "responsive", "testing", "e2e"],
  "commands": {
    "dev": "npm run dev",
    "build": "npm run build",
    "test": "npm test",
    "lint": "npm run lint"
  },
  "packageManager": "npm",
  "ci": {
    "workflowTemplate": "react",
    "runner": "ubuntu-latest",
    "runtime": {
      "name": "node",
      "version": "20",
      "setup": "actions/setup-node@v4",
      "cache": "npm"
    },
    "services": {},
    "steps": {
      "install": "npm ci",
      "build": "npm run build",
      "test": "npm test",
      "lint": "npm run lint"
    }
  }
}
